class Solution {
public:
int revno(int n){
    int rev=0;
    while(n>0){
        rev=rev*10+n%10;
        n/=10;
    }
    return rev;
}
    int countNicePairs(vector<int>& nums) {
        unordered_map<int,int>mp;
        const int MOD=1e9+7;
        long long ans=0;
        for(int i=0;i<nums.size();i++){
          int value=nums[i]-revno(nums[i]);

          ans=(ans+mp[value])%MOD;
          mp[value]++;
        }
        return ans;
    }
};
