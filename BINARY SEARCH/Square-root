class Solution {
public:
    int mySqrt(int x) {
        if(x==0) return 0;
        if(x==1) return 1;
        int low=0;
        int high=x;
        int ans=0;
       
        while(low<=high){
          int mid=(low+high)/2;   
        if(1LL*mid*mid<=x){
            ans=mid;
            low=mid+1;
        }
        else{
            high=mid-1;
        }
        }
        return ans;
        
    }
};
