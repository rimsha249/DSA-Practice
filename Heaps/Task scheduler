class Solution {
public:
    int leastInterval(vector<char>& tasks, int n) {
     vector<int>freq(26,0);
     for(char ch:tasks){
        freq[ch-'A']++;
     }   
     int maxfreq=0;
     for(int i=0;i<26;i++){
     maxfreq=max(maxfreq,freq[i]);
     }
     int countmax=0;
     for(int f:freq){
        if(f==maxfreq){
            countmax++;
        }
     }
     return max((int)tasks.size(),(maxfreq-1)*(n+1)+countmax);
    }
};
